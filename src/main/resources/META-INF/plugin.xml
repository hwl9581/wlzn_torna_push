<idea-plugin>
    <id>com.hwl.syncApi</id>
    <name>WLZN API SYNC</name>
    <vendor url="https://">HWL</vendor>

    <description><![CDATA[
        Torna API Sync - Spring MVC API documentation push tool.<br><br>
        将 Spring MVC 接口定义一键同步到 Torna 接口文档平台。<br><br>
        功能特性：<br>
        - 自动解析 Controller 方法的请求参数、返回值、注解描述等元数据<br>
        - 一键推送接口文档到 Torna 平台，支持覆盖更新<br>
        - 支持多项目配置，可管理多个 Torna 项目的 Token 并缓存选择<br>
        - 自动识别 application.yml / application.properties 中的 context-path<br>
        - 右键 Java/Groovy 的方法或类即可推送<br>
        ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectConfigurable
                parentId="tools"
                instance="com.wlzn.config.TornaSettingsConfigurable"
                id="com.wlzn.config.TornaSettingsConfigurable"
                displayName="Torna Sync"/>
    </extensions>

    <actions>
        <action id="com.wlzn.action.PushToTornaAction"
                class="com.wlzn.action.PushToTornaAction"
                text="Push to Torna"
                description="推送接口到 Torna 文档平台"
                icon="/icons/pushToTorna.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
